{
  "manifest_version": 3,
  "name": "SourceMap Loader",
  "version": "1.2.0",
  "description": "Automatically detects JS bundles and loads their source maps in DevTools.",
  "permissions": [
    "debugger",
    "storage",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
